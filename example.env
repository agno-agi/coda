# ============================================
# Coda Environment Configuration
# ============================================
# Copy to .env and fill in your values:
#   cp example.env .env
#
# WARNING: Never commit .env to version control.
# ============================================

# ------------------------------------------
# Required: API Keys
# ------------------------------------------

# OpenAI API key (required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# GitHub Personal Access Token (required)
# Fine-grained PAT with Contents RW, Pull Requests RW, Metadata R
# See GITHUB_ACCESS.md for setup instructions
GITHUB_TOKEN=

# ------------------------------------------
# Optional: Slack Integration
# ------------------------------------------
# See SLACK_CONNECT.md for setup instructions

# Bot User OAuth Token (OAuth & Permissions page)
SLACK_TOKEN=

# App Signing Secret (Basic Information > App Credentials)
SLACK_SIGNING_SECRET=

# ------------------------------------------
# Optional: Database
# ------------------------------------------
# Defaults below work for local development with docker compose.

# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_HOST=localhost
# DB_PORT=5432

# ------------------------------------------
# Optional: Model
# ------------------------------------------
# Override the model used by all Coda agents.
# Default: gpt-5.4

# CODA_MODEL=gpt-5.4
