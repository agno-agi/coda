# ============================================
# Coda Environment Configuration
# ============================================
# Copy to .env and fill in your values:
#   cp example.env .env
#
# WARNING: Never commit .env to version control.
# ============================================

# ------------------------------------------
# Required: API Keys
# ------------------------------------------

# OpenAI API key (required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# GitHub Personal Access Token (required)
# Fine-grained PAT with Contents RW, Pull Requests RW, Metadata R
# See docs/GITHUB_ACCESS.md for setup instructions
GITHUB_ACCESS_TOKEN=

# ------------------------------------------
# Optional: Slack Integration
# ------------------------------------------
# See docs/SLACK_CONNECT.md for setup instructions

# Bot User OAuth Token (OAuth & Permissions page)
SLACK_TOKEN=

# App Signing Secret (Basic Information > App Credentials)
SLACK_SIGNING_SECRET=

# ------------------------------------------
# Optional: Security (production only)
# ------------------------------------------
# RBAC is enabled automatically in production (RUNTIME_ENV=prd).
# Generate a key pair from os.agno.com → Settings.
# See: https://docs.agno.com/agent-os/security/overview

# JWT_VERIFICATION_KEY=

# ------------------------------------------
# Optional: Issue Triage
# ------------------------------------------
# Set to a Slack channel ID to enable daily issue triage posts.
# Find it in Slack: right-click channel → View details → ID at the bottom.

# TRIAGE_CHANNEL=

# Set to a Slack channel ID to enable daily activity digest posts.
# Can be the same channel as TRIAGE_CHANNEL or a different one.

# DIGEST_CHANNEL=

# ------------------------------------------
# Optional: Database
# ------------------------------------------
# Defaults below work for local development with docker compose.

# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_HOST=localhost
# DB_PORT=5432
